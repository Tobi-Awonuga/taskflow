generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id        Int     @id @default(autoincrement())
  name      String  @unique

  users     User[]
  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  role         String   @default("USER") // ADMIN | SUPER | USER
  passwordHash String

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignedTasks   Task[] @relation("AssignedTasks")
  createdTasks    Task[] @relation("CreatedTasks")
  cancelledTasks  Task[] @relation("CancelledTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
}

model Task {
  id               Int      @id @default(autoincrement())
  title            String
  description      String?
  status           String   @default("TODO")    // TODO | IN_PROGRESS | DONE | BLOCKED | CANCELLED
  priority         String   @default("MEDIUM")  // LOW | MEDIUM | HIGH | URGENT

  departmentId     Int?
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignedToUserId Int?
  assignedToUser   User?    @relation("AssignedTasks", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  createdByUserId  Int?
  createdByUser    User?    @relation("CreatedTasks", fields: [createdByUserId], references: [id], onDelete: SetNull)

  completedAt       DateTime?

  cancelledAt       DateTime?
  cancelledByUserId Int?
  cancelledByUser   User?    @relation("CancelledTasks", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  cancelReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([assignedToUserId])
  @@index([createdByUserId])
  @@index([cancelledByUserId])
}
