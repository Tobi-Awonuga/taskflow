# Copy this file to .env and fill in the values

PORT=3001
NODE_ENV=development

# Drizzle — SQLite database file path (relative to server/)
DATABASE_URL=./db/dev.sqlite

# Session secret – change to a long random string in production
SESSION_SECRET=change-me-to-a-random-secret
SESSION_TTL_DAYS=7

# CORS — allowed frontend origin
CORS_ORIGIN=http://localhost:5173
