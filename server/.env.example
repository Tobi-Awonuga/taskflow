# Copy this file to .env and fill in the values

PORT=3001
NODE_ENV=development

# Database (MySQL)
# Either provide a full mysql:// connection string in DATABASE_URL
# or fill in the MYSQL_* fields below.
DATABASE_URL=mysql://nectar:password@localhost:3306/nectar
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nectar
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=nectar
MYSQL_POOL_SIZE=10

# Session secret – change to a long random string in production
SESSION_SECRET=change-me-to-a-random-secret
SESSION_TTL_DAYS=7

# CORS — allowed frontend origin
CORS_ORIGIN=http://localhost:5173
