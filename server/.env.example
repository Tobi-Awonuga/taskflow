# Copy this file to .env and fill in your values.
# The defaults below match the Docker setup described in README.md.

PORT=3001
NODE_ENV=development

# ── Database (MySQL) ────────────────────────────────────────────────────────────
# Option A — full connection string (takes priority if set):
DATABASE_URL=mysql://nectar:nectarpass@127.0.0.1:3306/nectar

# Option B — individual fields (used if DATABASE_URL is not set):
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=nectar
MYSQL_PASSWORD=nectarpass
MYSQL_DATABASE=nectar
MYSQL_POOL_SIZE=10

# The Docker command that matches these defaults:
#   docker run --name nectar-mysql \
#     -e MYSQL_ROOT_PASSWORD=rootpass \
#     -e MYSQL_DATABASE=nectar \
#     -e MYSQL_USER=nectar \
#     -e MYSQL_PASSWORD=nectarpass \
#     -p 3306:3306 \
#     -d mysql:8

# ── Sessions ────────────────────────────────────────────────────────────────────
# Change SESSION_SECRET to a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_TTL_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────────────────
# Vite dev server origin — update for production.
CORS_ORIGIN=http://localhost:5173

# ── Email (optional) ────────────────────────────────────────────────────────────
# Leave blank to disable email sending (forgot-password will log tokens to console).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM="Nectar <no-reply@example.com>"
